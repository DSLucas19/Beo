# Cấu hình API Keys (Các khóa này khi nạp qua API sẽ được mã hóa lưu vào SQLite)
# Bạn có thể khai báo trực tiếp ở đây để phát triển nhanh cục bộ:
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_claude_api_key_here

# Cấu hình Default Provider & Model cho Beo
BEO_DEFAULT_PROVIDER=gemini
BEO_DEFAULT_MODEL=gemini/gemini-1.5-flash
BEO_DEFAULT_TEMPERATURE=0.2

# Khóa chủ mã hóa Fallback (dùng cho môi trường headless/server không có GUI keyring)
BEO_MASTER_KEY=beo_master_fallback_key_secret_string_12345!
